# --- Supabase (Paso 2) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Acceso al panel (Paso 3) ---
DASHBOARD_PASSWORD=          # la contraseña con la que entras al cockpit
AUTH_SECRET=                 # cadena aleatoria larga (30+ caracteres)

# --- Bot de Telegram (Paso 5, opcional pero recomendado) ---
ANTHROPIC_API_KEY=           # tu clave de api.anthropic.com (la usa Claude para interpretar tus mensajes)
TELEGRAM_BOT_TOKEN=          # token que te da @BotFather
TELEGRAM_WEBHOOK_SECRET=     # otra cadena aleatoria que tú inventas
OWNER_TELEGRAM_CHAT_ID=      # tu chat_id (el bot te lo dice la primera vez que le escribes)
